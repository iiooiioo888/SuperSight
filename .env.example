# SuperSight V3.0 環境變量配置
# 複製此文件為 .env 並填入實際值
# cp .env.example .env
#
# V3.0 新配置項：
# - VLM_CONTEXT_WINDOW: 1M tokens 超長上下文
# - MAX_IMAGE_RESOLUTION: 4K 原生支援
# - FP4_QUANTIZATION: Blackwell FP4 硬體加速
# - GPU_ARCHITECTURE: blackwell | ada | apple_m4 | cpu

# ─── 安全配置（必填）───────────────────────────
SUPERSIGHT_USERNAME=admin
SUPERSIGHT_PASSWORD=change_me_first

# ─── 服務器配置 ──────────────────────────────────
SUPERSIGHT_PORT=7860

# ─── Ollama V3.0 配置 ────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
VLM_MODEL_NAME=qwen3-vl:8b-fp4

# 設定 context window (默認 1M tokens)
VLM_CONTEXT_WINDOW=1048576

# ─── GPU 配置 (V3.0) ────────────────────────────
CUDA_VISIBLE_DEVICES=0

# 黑威爾架構: blackwell | ada | apple_m4 | cpu
GPU_ARCHITECTURE=blackwell

# FP4 量化加速 (Blackwell RTX 50 系列專用)
FP4_QUANTIZATION=True

# ─── Embedding 配置 (V3.0: bge-m4) ──────────────
EMBEDDING_DEVICE=cuda
EMBEDDING_MODEL=BAAI/bge-m4

# ─── 圖像解析度 (V3.0: 4K 原生) ────────────────
MAX_IMAGE_RESOLUTION=3840