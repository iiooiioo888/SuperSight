# SuperSight V2.1 環境變量配置
# 複製此文件為 .env 並填入實際值
# cp .env.example .env

# ─── 安全配置（必填）───────────────────────────
# 強密碼策略：至少 8 位，包含大小寫字母和數字
SUPERSIGHT_USERNAME=admin
SUPERSIGHT_PASSWORD=change_me_first

# ─── 服務器配置 ──────────────────────────────────
SUPERSIGHT_PORT=7860

# ─── Ollama 配置 ──────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
VLM_MODEL_NAME=qwen2.5-vl:7b-instruct-q4_k_m

# ─── GPU 配置 ────────────────────────────────────
CUDA_VISIBLE_DEVICES=0

# ─── Embedding 配置 ──────────────────────────────
# 若無 GPU，改為 "cpu"
EMBEDDING_DEVICE=cuda